# === Server ===
PORT=3000
PUBLIC_URL=https://yourdomain.mn

# === QPay Merchant ===
# qpay.mn-с авна. Sandbox: https://merchant-sandbox.qpay.mn/v2
QPAY_BASE_URL=https://merchant.qpay.mn/v2
QPAY_CLIENT_ID=your_client_id
QPAY_CLIENT_SECRET=your_client_secret
QPAY_INVOICE_CODE=your_invoice_code

# И-баримт автоматаар үүсгэх (Ebarimt 3.0, /v2/ebarimt_v3/create)
EBARIMT_ENABLED=false

# === Token TTL ===
# Худалдан авсан линкийн хүчинтэй хугацаа (цагаар)
WATCH_TOKEN_TTL_HOURS=48
# Хэдэн удаа үзэж болох
WATCH_TOKEN_MAX_VIEWS=3

# === Bunny Stream (кино хостинг) ===
# https://bunny.net Stream service
BUNNY_LIBRARY_ID=
BUNNY_CDN_HOSTNAME=vz-xxxxxxxx.b-cdn.net
BUNNY_TOKEN_KEY=your_token_authentication_key

# === ManyChat (Optional — хэрэглэгч рүү мессеж push илгээхэд) ===
MANYCHAT_API_KEY=

# === Админ тайлангийн нууц түлхүүр (/admin?key=...) ===
ADMIN_KEY=
